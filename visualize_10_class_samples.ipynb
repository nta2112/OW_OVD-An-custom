    "# -------------------------------------------------------------------\n",
    "# Load model – Two-stage checkpoint loading\n",
    "#\n",
    "# WHY TWO STAGES?\n",
    "# t3_best.pth was saved incrementally – it only contains weights that\n",
    "# changed during Task-3 training (embeddings + att_embeddings).\n",
    "# The bbox regression head (reg_preds / cls_preds) was FROZEN during\n",
    "# Task-3 training and was NOT saved in t3_best.pth.\n",
    "# Those frozen weights live in t1_best.pth (the first full checkpoint).\n",
    "#\n",
    "# Loading order:\n",
    "#   1. t1_best.pth  → full backbone + neck + head weights (reg_preds, cls_preds, etc.)\n",
    "#   2. t3_best.pth  → overwrites embeddings and att_embeddings with Task-3 values\n",
    "# -------------------------------------------------------------------\n",
    "import re, os, sys, glob, importlib, importlib.util, importlib.metadata, torch\n",
    "\n",
    "# ── Patch mmcv version ceiling ────────────────────────────────────\n",
    "def _patch_ceiling(pkg_name):\n",
    "    importlib.invalidate_caches()\n",
    "    spec = importlib.util.find_spec(pkg_name)\n",
    "    if not (spec and spec.origin): return\n",
    "    path = spec.origin\n",
    "    src  = open(path, encoding=\"utf-8\").read()\n",
    "    m = re.search(r\"mmcv_maximum_version\\s*=\\s*[\\\"']([^\\\"\\']+)[\\\"']\", src)\n",
    "    if not m: return\n",
    "    print(f\"[patch] {pkg_name}: ceiling = {m.group(1)!r}\")\n",
    "    new_src = re.sub(r\"(mmcv_maximum_version\\s*=\\s*)[\\\"'][^\\\"\\']+[\\\"']\", r\"\\g<1>'2.3.0'\", src)\n",
    "    if new_src != src:\n",
    "        open(path, \"w\", encoding=\"utf-8\").write(new_src)\n",
    "        print(f\"[patch] {pkg_name}: patched -> '2.3.0'\")\n",
    "    else:\n",
    "        print(f\"[patch] {pkg_name}: already '2.3.0'\")\n",
    "    cache_dir = os.path.join(os.path.dirname(path), \"__pycache__\")\n",
    "    for pyc in glob.glob(os.path.join(cache_dir, \"__init__*.pyc\")):\n",
    "        try: os.remove(pyc); print(f\"[patch] removed .pyc: {pyc}\")\n",
    "        except OSError: pass\n",
    "\n",
    "_patch_ceiling(\"mmdet\")\n",
    "_patch_ceiling(\"mmyolo\")\n",
    "\n",
    "# ── Evict stale modules ───────────────────────────────────────────\n",
    "_stale = [m for m in sys.modules if m.split(\".\")[0] in (\"mmcv\",\"mmdet\",\"mmyolo\",\"mmengine\",\"yolo_world\")]\n",
    "for _m in _stale: del sys.modules[_m]\n",
    "importlib.invalidate_caches()\n",
    "print(f\"[patch] Evicted {len(_stale)} stale modules\")\n",
    "\n",
    "# ── Ensure repo root on sys.path ─────────────────────────────────\n",
    "_repo_root = os.path.abspath(os.getcwd())\n",
    "for _c in [_repo_root, \"/kaggle/working/OW_OVD\", \"/kaggle/working\"]:\n",
    "    if os.path.isdir(os.path.join(_c, \"yolo_world\")):\n",
    "        _repo_root = _c; break\n",
    "if _repo_root not in sys.path:\n",
    "    sys.path.insert(0, _repo_root)\n",
    "print(f\"[patch] repo_root = {_repo_root}\")\n",
    "\n",
    "# ── Import OpenMMLab ──────────────────────────────────────────────\n",
    "import mmcv, mmyolo  # noqa\n",
    "print(\"mmcv:\", mmcv.__version__)\n",
    "print(\"mmyolo:\", importlib.metadata.version(\"mmyolo\"))\n",
    "\n",
    "from mmdet.apis import init_detector\n",
    "from mmengine.runner import load_checkpoint\n",
    "from mmengine.config import Config\n",
    "\n",
    "import yolo_world, yolo_world.models  # noqa – registers OurDetector, OurHead, etc.\n",
    "print(\"[ok] yolo_world registered\")\n",
    "\n",
    "from PIL import Image, ImageDraw, ImageFont\n",
    "\n",
    "# ── Patch torch.load ─────────────────────────────────────────────\n",
    "if getattr(torch.load, \"_owd_safe_patch\", False):\n",
    "    torch.load = getattr(torch.load, \"_owd_original\", torch.load)\n",
    "_orig_load = torch.load\n",
    "def _safe_load(*a, **kw): kw.setdefault(\"weights_only\", False); return _orig_load(*a, **kw)\n",
    "_safe_load._owd_safe_patch = True\n",
    "_safe_load._owd_original   = _orig_load\n",
    "torch.load = _safe_load\n",
    "\n",
    "# ── Bước 7: Khởi tạo kiến trúc model (không load checkpoint) ─────\n",
    "print(\"\\nInitializing model architecture...\")\n",
    "model = init_detector(CFG_PATH, checkpoint=None, device=\"cpu\")\n",
    "\n",
    "# ── Bước 8: Load t1_best.pth – chứa đầy đủ reg_preds / cls_preds ─\n",
    "print(f\"\\n[Stage 1] Loading FULL weights from: {T1_CKPT}\")\n",
    "load_checkpoint(model, T1_CKPT, map_location=\"cpu\")\n",
    "print(\"[Stage 1] Done.\")\n",
    "\n",
    "# Verify reg_preds were loaded (values should no longer be random)\n",
    "for name, param in model.named_parameters():\n",
    "    if 'reg_pred' in name and 'weight' in name:\n",
    "        print(f\"  reg_pred check – {name}: mean={param.data.mean():.4f}, std={param.data.std():.4f}\")\n",
    "        break\n",
    "\n",
    "# ── Bước 9: Điều chỉnh att_embeddings shape về 1925 trước khi load t3 ──\n",
    "if hasattr(model, \"bbox_head\") and hasattr(model.bbox_head, \"select_att\"):\n",
    "    print(\"\\nCalling select_att() to set att_embeddings shape to 1925...\")\n",
    "    model.bbox_head.select_att(per_class=25)\n",
    "    print(\"att_embeddings shape:\", model.bbox_head.att_embeddings.shape)\n",
    "\n",
    "# ── Bước 10: Load t3_best.pth – chồng lên embeddings + att_embeddings ──\n",
    "print(f\"\\n[Stage 2] Loading Task-3 weights from: {T3_CKPT}\")\n",
    "t3_sd = torch.load(T3_CKPT, map_location=\"cpu\")\n",
    "t3_sd = t3_sd.get('state_dict', t3_sd)\n",
    "\n",
    "# Chỉ áp dụng các keys có trong cả checkpoint và model (strict=False)\n",
    "result = model.load_state_dict(t3_sd, strict=False)\n",
    "loaded = [k for k in t3_sd.keys() if k not in result.missing_keys]\n",
    "print(f\"[Stage 2] Applied {len(loaded)} keys from t3_best.pth\")\n",
    "print(f\"[Stage 2] Keys: {loaded[:10]}\")\n",
    "if result.missing_keys:\n",
    "    print(f\"[Stage 2] Missing (OK for frozen): {result.missing_keys[:5]}\")\n",
    "if result.unexpected_keys:\n",
    "    print(f\"[Stage 2] Unexpected: {result.unexpected_keys[:5]}\")\n",
    "\n",
    "# ── Bước 11: Gán class_names từ config ───────────────────────────\n",
    "cfg = Config.fromfile(CFG_PATH)\n",
    "if hasattr(cfg, \"class_names\"):\n",
    "    active_classes = list(cfg.class_names)[:77]\n",
    "    model.dataset_meta = {\"classes\": active_classes}\n",
    "    print(f\"\\nClass names: {len(active_classes)} classes from IP102\")\n",
    "else:\n",
    "    model.dataset_meta = {\"classes\": [f\"pest_{i}\" for i in range(77)]}\n",
    "\n",
    "class_names = model.dataset_meta[\"classes\"]\n",
    "UNKNOWN_ID  = 80\n",
    "model.eval()\n",
    "print(\"\\nModel ready for inference!\")"
   ]
  },
